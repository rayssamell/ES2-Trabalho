<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE hibernate-configuration PUBLIC
 "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
 "http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:5432/es2?ssl=false&amp;sslmode=disable</property>
        
        <property name="hibernate.connection.username">postgres</property>
        <property name="hibernate.connection.password">suasenha123</property>
        
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>

        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <property name="hibernate.hbm2ddl.auto">update</property>

        <mapping class="com.trabalho_es2.model.Produto"/>
        <mapping class="com.trabalho_es2.model.ProdutoEletronico"/>
        <mapping class="com.trabalho_es2.model.ProdutoPerecivel"/>
        <mapping class="com.trabalho_es2.model.Item"/>
        <mapping class="com.trabalho_es2.model.Pedido"/>
    </session-factory>
</hibernate-configuration>